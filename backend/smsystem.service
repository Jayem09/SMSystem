[Unit]
Description=SMSystem Backend API
After=network.target mysql.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/SMSytem/backend
ExecStart=/root/SMSytem/backend/smsystem-server
Restart=always
RestartSec=5

Environment="GIN_MODE=release"

StandardOutput=append:/root/SMSytem/backend/server.log
StandardError=append:/root/SMSytem/backend/server.log

[Install]
WantedBy=multi-user.target
