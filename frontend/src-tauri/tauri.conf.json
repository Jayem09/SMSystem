{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SMSytem",
  "version": "4.0.4",
  "identifier": "com.smsystem.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SMSytem Dashboard",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; connect-src 'self' http://* https://* http://168.144.46.137:*; img-src 'self' data: blob:; font-src 'self' data:; script-src 'self' 'unsafe-inline' 'unsafe-eval'"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Jayem09/SMSystem/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": "./SMSytem.entitlements"
    },
    "shortDescription": "SMS Sales Management System",
    "longDescription": "A comprehensive desktop application for managing sales, inventory, customers, and more.",
    "copyright": "Copyright © 2026 SMSystem",
    "category": "Business"
  }
}